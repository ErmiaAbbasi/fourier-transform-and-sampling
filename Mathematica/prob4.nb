Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"xSampled", "[", "t_", "]"}], ":=", " ", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"n", "*", "Ts"}], "]"}], "*", 
      RowBox[{"DiracDelta", "[", 
       RowBox[{"t", "-", 
        RowBox[{"n", "*", "Ts"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", 
       RowBox[{"-", "nmax"}], ",", "nmax"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[170]:=",ExpressionUUID->"a84b3321-8a10-4246-ada2-6bba2fea5a32"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"X", "[", "f_", "]"}], "=", " ", 
   RowBox[{"FourierTransform", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"xSampled", "[", "t", "]"}], " ", "*", "Ts"}], ",", "t", ",", 
     "f", ",", 
     RowBox[{"FourierParameters", "->", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{
         RowBox[{"-", "2"}], "*", "Pi"}]}], "}"}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[171]:=",ExpressionUUID->"64478314-59e2-1c40-a9b9-e2760b2a758c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Re", "[", 
     RowBox[{"X", "[", "f", "]"}], "]"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"f", ",", 
     RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
   RowBox[{"Exclusions", "->", "None"}]}], "]"}]], "Input",
 CellLabel->
  "In[172]:=",ExpressionUUID->"7529a2c4-820c-0f43-bdcc-5f3f0be369f2"],

