 RowBox[{
  RowBox[{"Ts", "=", "0.3"}], ";"}]], "Input",
 CellLabel->
  "In[191]:=",ExpressionUUID->"0285a854-72b9-3945-a10b-4257e13e572e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"xSampled", "[", "t_", "]"}], ":=", " ", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"n", "*", "Ts"}], "]"}], "*", 
      RowBox[{"DiracDelta", "[", 
       RowBox[{"t", "-", 
        RowBox[{"n", "*", "Ts"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", 
       RowBox[{"-", "nmax"}], ",", "nmax"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[192]:=",ExpressionUUID->"43969637-546b-2742-b9ac-d4c790b4d75d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"X", "[", "f_", "]"}], "=", " ", 
   RowBox[{"FourierTransform", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"xSampled", "[", "t", "]"}], " ", "*", "Ts"}], ",", "t", ",", 
     "f", ",", 
     RowBox[{"FourierParameters", "->", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", 
        RowBox[{
         RowBox[{"-", "2"}], "*", "Pi"}]}], "}"}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->
  "In[193]:=",ExpressionUUID->"ab52c19d-c68c-2e47-bf56-7f370ac643ee"],

